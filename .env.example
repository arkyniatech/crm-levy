# Webhook do n8n que processa upload de NF-e (ZIP ou XML)
VITE_N8N_NFE_WEBHOOK_URL=

# Webhook do n8n que envia mensagens de WhatsApp (fluxo WA Send)
VITE_N8N_WA_SEND_URL=
